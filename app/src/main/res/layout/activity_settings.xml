<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SettingsActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            app:title="设置"
            app:titleTextAppearance="@style/ToolbarTitle" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="24dp">

            <!-- 主题设置 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="主题"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="切换应用明暗主题"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnThemeLight"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:text="浅色" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnThemeDark"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:text="深色" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnThemeSystem"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="跟随系统" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 浏览器标识设置 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="浏览器标识"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="切换浏览器标识（电脑/手机模式）"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnUserAgentPC"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:text="电脑模式" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnUserAgentMobile"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="手机模式" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 主题色设置 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="主题色"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="选择应用的主题色"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="14sp" />

                    <!-- 第一行：4个颜色 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnColorPurple"
                            style="@style/Widget.MaterialComponents.Button.Icon"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:layout_marginHorizontal="6dp"
                            android:contentDescription="紫色"
                            app:backgroundTint="#6750A4"
                            app:cornerRadius="26dp"
                            app:strokeWidth="0dp"
                            app:strokeColor="@color/md_theme_light_surface"
                            app:rippleColor="#33FFFFFF" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnColorBlue"
                            style="@style/Widget.MaterialComponents.Button.Icon"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:layout_marginHorizontal="6dp"
                            android:contentDescription="蓝色"
                            app:backgroundTint="#1976D2"
                            app:cornerRadius="26dp"
                            app:strokeWidth="0dp"
                            app:strokeColor="@color/md_theme_light_surface"
                            app:rippleColor="#33FFFFFF" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnColorTeal"
                            style="@style/Widget.MaterialComponents.Button.Icon"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:layout_marginHorizontal="6dp"
                            android:contentDescription="青色"
                            app:backgroundTint="#00796B"
                            app:cornerRadius="26dp"
                            app:strokeWidth="0dp"
                            app:strokeColor="@color/md_theme_light_surface"
                            app:rippleColor="#33FFFFFF" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnColorRed"
                            style="@style/Widget.MaterialComponents.Button.Icon"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:layout_marginHorizontal="6dp"
                            android:contentDescription="红色"
                            app:backgroundTint="#C62828"
                            app:cornerRadius="26dp"
                            app:strokeWidth="0dp"
                            app:strokeColor="@color/md_theme_light_surface"
                            app:rippleColor="#33FFFFFF" />

                    </LinearLayout>

                    <!-- 第二行：3个颜色 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnColorOrange"
                            style="@style/Widget.MaterialComponents.Button.Icon"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:layout_marginHorizontal="6dp"
                            android:contentDescription="橙色"
                            app:backgroundTint="#E65100"
                            app:cornerRadius="26dp"
                            app:strokeWidth="0dp"
                            app:strokeColor="@color/md_theme_light_surface"
                            app:rippleColor="#33FFFFFF" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnColorGreen"
                            style="@style/Widget.MaterialComponents.Button.Icon"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:layout_marginHorizontal="6dp"
                            android:contentDescription="绿色"
                            app:backgroundTint="#2E7D32"
                            app:cornerRadius="26dp"
                            app:strokeWidth="0dp"
                            app:strokeColor="@color/md_theme_light_surface"
                            app:rippleColor="#33FFFFFF" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnColorPink"
                            style="@style/Widget.MaterialComponents.Button.Icon"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:layout_marginHorizontal="6dp"
                            android:contentDescription="粉色"
                            app:backgroundTint="#AD1457"
                            app:cornerRadius="26dp"
                            app:strokeWidth="0dp"
                            app:strokeColor="@color/md_theme_light_surface"
                            app:rippleColor="#33FFFFFF" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 插件管理 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="插件"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="管理浏览器插件"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/pluginContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 清除缓存设置 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="清除缓存"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="清除WebView缓存和历史记录"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="14sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearCache"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="清除缓存" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 关于应用 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAbout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="关于"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvVersion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="版本: 1.7"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="简单浏览器 - 轻量级Android浏览器"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="24sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginStart="8dp" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="8dp"
                        android:background="?attr/colorOutlineVariant" />

                    <TextView
                        android:id="@+id/tvGitHub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="github.com/knowlily/listen-to"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="构建于 2026年5月8日"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>