<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/findBar"
    android:layout_width="match_parent"
    android:layout_height="44dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingEnd="4dp"
    android:visibility="gone">

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/findInputLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="4dp"
        android:layout_weight="1"
        app:endIconMode="clear_text"
        app:placeholderText="在页面中查找">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etFindQuery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:singleLine="true" />

    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/tvFindCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="4dp"
        android:text="0/0"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="12sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFindPrev"
        style="@style/Widget.MaterialComponents.Button.Icon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:contentDescription="上一个"
        app:icon="@drawable/ic_find_up"
        app:iconSize="18dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFindNext"
        style="@style/Widget.MaterialComponents.Button.Icon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:contentDescription="下一个"
        app:icon="@drawable/ic_find_down"
        app:iconSize="18dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFindClose"
        style="@style/Widget.MaterialComponents.Button.Icon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:contentDescription="关闭"
        app:icon="@drawable/ic_close"
        app:iconSize="18dp" />

</LinearLayout>
